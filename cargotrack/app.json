{
  "expo": {
    "name": "CargoTrack Pro",
    "slug": "cargotrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
  "backgroundColor": "#007AFF",
  "resizeMode": "contain"
},
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.njerirozzy.cargotrack"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow CargoTrack Pro to access your camera to capture shipment photos."
        }
      ],
      [
        "expo-location",
        {
          "locationPermission": "Allow CargoTrack Pro to access your location to track shipments."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8378916f-128b-4a6a-b98f-fe2b32e2fad5"
      }
    }
  }
}